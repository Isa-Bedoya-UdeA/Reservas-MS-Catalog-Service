# ======================
# SPRING PROFILE
# ======================
SPRING_PROFILE=dev

# ======================
# DATABASE CONFIG - SUPABASE (Transaction Pooler - IPv4 compatible)
# ======================
# MS-AUTH - URL limpia sin credenciales (las credenciales van en DB_USER y DB_PASSWORD)
DB_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USER=postgres.[ID PROYECTO]
DB_PASSWORD=[CONTRASEÑA]

# MS-CATALOG
# DB_URL_CATALOG=jdbc:postgresql://db.xxx.supabase.co:5432/postgres?sslmode=require
# DB_USER_CATALOG=postgres.your-project-ref-catalog
# DB_PASSWORD_CATALOG=tu-contraseña-segura

# ======================
# JWT CONFIG (MISMO VALOR EN TODOS LOS MS)
# ======================
JWT_SECRET=[TOKEN]
JWT_EXPIRATION=[EXPIRATION]

# ======================
# EXTERNAL SERVICES URLs (locales por ahora)
# ======================
SERVICES_AUTH_URL=http://localhost:[PUERTO]
SERVICES_CATALOG_URL=http://localhost:[PUERTO]
SERVICES_RESOURCE_URL=http://localhost:[PUERTO]
SERVICES_RESERVATION_URL=http://localhost:[PUERTO]